---
export interface Props {
  product: string;
  image: string;
  rating: number;
  price?: string;
  affiliate_url: string;
  retailer: string;
  pros?: string[];
  cons?: string[];
  summary?: string;
  category?: string;
  featured?: boolean;
}

const { 
  product, 
  image, 
  rating, 
  price, 
  affiliate_url, 
  retailer, 
  pros = [], 
  cons = [], 
  summary,
  category = "equipment",
  featured = false
} = Astro.props;

const starFull = '★';
const starEmpty = '☆';
const stars = starFull.repeat(Math.floor(rating)) + starEmpty.repeat(5 - Math.floor(rating));

// Rating color based on score
const getRatingColor = (rating: number) => {
  if (rating >= 8.5) return 'text-green-600 bg-green-50';
  if (rating >= 7.0) return 'text-yellow-600 bg-yellow-50';
  if (rating >= 6.0) return 'text-orange-600 bg-orange-50';
  return 'text-red-600 bg-red-50';
};

const ratingColorClass = getRatingColor(rating);
---

<div class={`bg-white rounded-lg border border-gray-200 p-6 hover:shadow-lg transition-shadow ${featured ? 'border-2 border-green-300 shadow-md' : ''}`}>
  {featured && (
    <div class="absolute -top-3 -right-3 bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full">
      EDITOR'S PICK
    </div>
  )}
  
  <!-- Product Image -->
  <div class="aspect-square w-full mb-4 bg-gray-50 rounded-lg overflow-hidden relative">
    <img 
      src={image} 
      alt={product}
      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
    />
    {featured && (
      <div class="absolute top-3 left-3">
        <span class="bg-green-600 text-white text-xs font-bold px-2 py-1 rounded">
          #1 PICK
        </span>
      </div>
    )}
  </div>
  
  <!-- Product Info -->
  <div class="space-y-3">
    <h3 class="font-semibold text-lg text-gray-900 line-clamp-2">{product}</h3>
    
    <!-- Rating -->
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-2">
        <span class="text-yellow-400 text-lg">{stars}</span>
        <span class={`text-sm font-bold px-2 py-1 rounded ${ratingColorClass}`}>
          {rating}/10
        </span>
      </div>
      {category && (
        <span class="text-xs text-gray-500 uppercase tracking-wide">
          {category}
        </span>
      )}
    </div>
    
    <!-- Summary -->
    {summary && (
      <p class="text-gray-600 text-sm line-clamp-3">{summary}</p>
    )}
    
    <!-- Pros/Cons -->
    {(pros.length > 0 || cons.length > 0) && (
      <div class="grid grid-cols-1 gap-3 text-xs">
        {pros.length > 0 && (
          <div>
            <h4 class="font-medium text-green-700 mb-2 flex items-center">
              <span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>
              Pros:
            </h4>
            <ul class="space-y-1 text-gray-600">
              {pros.slice(0, 3).map(pro => (
                <li class="flex items-start space-x-2">
                  <span class="text-green-500 mt-0.5">+</span>
                  <span class="flex-1">{pro}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        {cons.length > 0 && (
          <div>
            <h4 class="font-medium text-red-700 mb-2 flex items-center">
              <span class="w-2 h-2 bg-red-500 rounded-full mr-2"></span>
              Cons:
            </h4>
            <ul class="space-y-1 text-gray-600">
              {cons.slice(0, 3).map(con => (
                <li class="flex items-start space-x-2">
                  <span class="text-red-500 mt-0.5">-</span>
                  <span class="flex-1">{con}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )}
    
    <!-- Price & CTA -->
    <div class="pt-3 border-t border-gray-100">
      <div class="flex items-center justify-between mb-3">
        {price && (
          <div class="text-lg font-bold text-gray-900">{price}</div>
        )}
        <span class="text-xs text-gray-500">at {retailer}</span>
      </div>
      
      <a 
        href={affiliate_url}
        target="_blank"
        rel="nofollow sponsored"
        class={`w-full inline-flex items-center justify-center px-4 py-3 text-white text-sm font-semibold rounded-lg transition-colors ${
          featured 
            ? 'bg-green-700 hover:bg-green-800' 
            : 'bg-gray-800 hover:bg-gray-900'
        }`}
        onclick="trackAffiliateClick(this)"
      >
        Check Price at {retailer}
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
    </div>
  </div>
</div>

<script>
function trackAffiliateClick(element) {
  // Track affiliate link clicks (placeholder for analytics)
  const product = element.closest('.bg-white').querySelector('h3').textContent;
  console.log('Affiliate click:', product, element.href);
  
  // You can integrate with Google Analytics, Plausible, etc. here
  if (typeof gtag !== 'undefined') {
    gtag('event', 'affiliate_click', {
      'product_name': product,
      'outbound_url': element.href
    });
  }
}
</script>