---
export interface Props {
  product: string;
  image: string;
  rating: number;
  price?: string;
  affiliate_url: string;
  retailer: string;
  pros?: string[];
  cons?: string[];
  summary?: string;
}

const { 
  product, 
  image, 
  rating, 
  price, 
  affiliate_url, 
  retailer, 
  pros = [], 
  cons = [], 
  summary 
} = Astro.props;

const starFull = '★';
const starEmpty = '☆';
const stars = starFull.repeat(rating) + starEmpty.repeat(5 - rating);
---

<div class="bg-white rounded-lg border border-gray-200 p-6 hover:shadow-lg transition-shadow">
  <!-- Product Image -->
  <div class="aspect-square w-full mb-4 bg-gray-50 rounded-lg overflow-hidden">
    <img 
      src={image} 
      alt={product}
      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
    />
  </div>
  
  <!-- Product Info -->
  <div class="space-y-3">
    <h3 class="font-semibold text-lg text-gray-900 line-clamp-2">{product}</h3>
    
    <!-- Rating -->
    <div class="flex items-center space-x-2">
      <span class="text-yellow-400 text-lg">{stars}</span>
      <span class="text-sm text-gray-600">({rating}/5)</span>
    </div>
    
    <!-- Summary -->
    {summary && (
      <p class="text-gray-600 text-sm line-clamp-3">{summary}</p>
    )}
    
    <!-- Pros/Cons -->
    {(pros.length > 0 || cons.length > 0) && (
      <div class="grid grid-cols-2 gap-3 text-xs">
        {pros.length > 0 && (
          <div>
            <h4 class="font-medium text-green-700 mb-1">Pros:</h4>
            <ul class="space-y-1 text-gray-600">
              {pros.slice(0, 3).map(pro => (
                <li class="flex items-start space-x-1">
                  <span class="text-green-500 mt-0.5">+</span>
                  <span>{pro}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        {cons.length > 0 && (
          <div>
            <h4 class="font-medium text-red-700 mb-1">Cons:</h4>
            <ul class="space-y-1 text-gray-600">
              {cons.slice(0, 3).map(con => (
                <li class="flex items-start space-x-1">
                  <span class="text-red-500 mt-0.5">-</span>
                  <span>{con}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )}
    
    <!-- Price & CTA -->
    <div class="pt-3 border-t border-gray-100">
      <div class="flex items-center justify-between">
        {price && (
          <div class="text-lg font-semibold text-gray-900">{price}</div>
        )}
        <a 
          href={affiliate_url}
          target="_blank"
          rel="nofollow sponsored"
          class="inline-flex items-center px-4 py-2 bg-green-700 text-white text-sm font-medium rounded-md hover:bg-green-800 transition-colors"
          onclick="trackAffiliateClick(this)"
        >
          Check Price at {retailer}
          <svg class="ml-1 w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        </a>
      </div>
      <p class="text-xs text-gray-500 mt-1">at {retailer}</p>
    </div>
  </div>
</div>

<script>
function trackAffiliateClick(element) {
  // Track affiliate link clicks (placeholder for analytics)
  const product = element.closest('.bg-white').querySelector('h3').textContent;
  console.log('Affiliate click:', product, element.href);
  
  // You can integrate with Google Analytics, Plausible, etc. here
  if (typeof gtag !== 'undefined') {
    gtag('event', 'affiliate_click', {
      'product_name': product,
      'outbound_url': element.href
    });
  }
}
</script>