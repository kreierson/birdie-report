---
import BaseLayout from './BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';

export interface Props {
  content: any;
}

const { content } = Astro.props;
const { title, description, date, category, tags, author, featured_image, affiliate_links } = content;

// Get related posts
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(post => 
    post.data.category === category && 
    post.data.title !== title
  )
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

// Schema markup for articles
const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": new URL(featured_image, 'https://birdiereport.com').toString(),
  "author": {
    "@type": "Person",
    "name": author
  },
  "publisher": {
    "@type": "Organization",
    "name": "The Birdie Report",
    "logo": {
      "@type": "ImageObject",
      "url": "https://birdiereport.com/logo.png"
    }
  },
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, 'https://birdiereport.com').toString()
  }
};
---

<BaseLayout 
  title={title}
  description={description}
  image={featured_image}
>
  <!-- Schema markup -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Article Header -->
    <header class="mb-12">
      <!-- Featured Image -->
      <div class="aspect-video w-full mb-8 rounded-lg overflow-hidden">
        <img 
          src={featured_image} 
          alt={title}
          class="w-full h-full object-cover"
        />
      </div>
      
      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 mb-6">
        <span class={`px-3 py-1 rounded-full text-xs font-medium ${
          category === 'reviews' ? 'bg-green-100 text-green-800' :
          category === 'tips' ? 'bg-blue-100 text-blue-800' :
          category === 'deals' ? 'bg-orange-100 text-orange-800' :
          'bg-gray-100 text-gray-800'
        }`}>
          {category}
        </span>
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('en-US', { 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
          })}
        </time>
        <span>By {author}</span>
        <span>•</span>
        <span id="reading-time">5 min read</span>
      </div>
      
      <!-- Title -->
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">
        {title}
      </h1>
      
      <!-- Description -->
      <p class="text-xl text-gray-600 leading-relaxed">
        {description}
      </p>
      
      <!-- Tags -->
      {tags && tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="px-2 py-1 bg-gray-100 text-gray-600 text-sm rounded">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- Article Content -->
    <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-p:text-gray-700 prose-strong:text-gray-900 prose-a:text-green-700 hover:prose-a:text-green-800 prose-blockquote:border-green-500">
      <slot />
    </div>

    <!-- Affiliate Links Section -->
    {affiliate_links && affiliate_links.length > 0 && (
      <div class="mt-12 p-6 bg-green-50 rounded-lg border border-green-200">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">🛍️ Shop the Products Mentioned</h3>
        <div class="grid gap-4">
          {affiliate_links.map(link => (
            <div class="flex items-center justify-between p-4 bg-white rounded border">
              <div>
                <h4 class="font-medium text-gray-900">{link.product}</h4>
                {link.price && <p class="text-sm text-gray-600">{link.price} at {link.retailer}</p>}
              </div>
              <a 
                href={link.url}
                target="_blank"
                rel="nofollow sponsored"
                class="px-4 py-2 bg-green-700 text-white rounded hover:bg-green-800 transition-colors text-sm font-medium"
              >
                Check Price
              </a>
            </div>
          ))}
        </div>
        <p class="text-xs text-gray-500 mt-4">
          *We earn a small commission if you purchase through these links, at no extra cost to you.
        </p>
      </div>
    )}

    <!-- Newsletter Signup -->
    <div class="mt-16">
      <NewsletterSignup variant="card" />
    </div>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map(post => (
            <article class="group">
              <a href={`/blog/${post.slug}/`} class="block">
                <img 
                  src={post.data.featured_image} 
                  alt={post.data.title}
                  class="w-full h-40 object-cover rounded-lg mb-4 group-hover:opacity-90 transition-opacity"
                />
              </a>
              
              <div class="space-y-2">
                <span class={`inline-block px-2 py-1 text-xs font-medium rounded ${
                  post.data.category === 'reviews' ? 'bg-green-100 text-green-800' :
                  post.data.category === 'tips' ? 'bg-blue-100 text-blue-800' :
                  post.data.category === 'deals' ? 'bg-orange-100 text-orange-800' :
                  'bg-gray-100 text-gray-800'
                }`}>
                  {post.data.category}
                </span>
                
                <h3 class="font-semibold text-gray-900 line-clamp-2">
                  <a href={`/blog/${post.slug}/`} class="hover:text-green-700 transition-colors">
                    {post.data.title}
                  </a>
                </h3>
                
                <p class="text-sm text-gray-600 line-clamp-2">
                  {post.data.description}
                </p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </article>

  <!-- Author Bio -->
  <section class="bg-gray-50 py-12 mt-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">{author}</h3>
        <p class="text-gray-600 mb-4">
          Kyle is a 2-handicap golfer and obsessive equipment tester who's played 
          everything from North Dakota's hidden gems to Pebble Beach. He shares 
          honest, no-BS reviews to help golfers make smarter purchasing decisions.
        </p>
        <div class="flex space-x-4 text-sm">
          <span class="text-gray-500">🏌️ 2 Handicap</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Calculate reading time
  const article = document.querySelector('article .prose');
  if (article) {
    const text = article.textContent;
    const words = text.trim().split(/\s+/).length;
    const readingTime = Math.ceil(words / 200);
    const el = document.getElementById('reading-time');
    if (el) el.textContent = `${readingTime} min read`;

    // Open all external/affiliate links in new tab
    article.querySelectorAll('a[href]').forEach(link => {
      if (link.hostname !== window.location.hostname) {
        link.setAttribute('target', '_blank');
        link.setAttribute('rel', 'nofollow sponsored noopener');
      }
    });
  }
});
</script>