---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog').catch(() => []);
const posts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout 
  title="All Articles | The Birdie Report"
  description="Every article, review, and guide from The Birdie Report. Golf equipment reviews, tips, deals, and more."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">All Articles</h1>
      <p class="text-xl text-gray-600">Everything we've published, newest first.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map(post => (
        <article class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
          <a href={`/blog/${post.slug}/`}>
            <img 
              src={post.data.featured_image} 
              alt={post.data.title}
              class="w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </a>
          <div class="p-6">
            <div class="flex items-center space-x-2 text-sm text-gray-500 mb-2">
              <span class="px-2 py-1 bg-green-100 text-green-700 rounded text-xs font-medium capitalize">
                {post.data.category}
              </span>
              <time>{new Date(post.data.date).toLocaleDateString()}</time>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3 line-clamp-2">
              <a href={`/blog/${post.slug}/`} class="hover:text-green-700 transition-colors">
                {post.data.title}
              </a>
            </h3>
            <p class="text-gray-600 text-sm line-clamp-3">{post.data.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
