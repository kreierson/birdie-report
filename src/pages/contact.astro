---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact Us | The Birdie Report"
  description="Get in touch with The Birdie Report team."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Contact Us</h1>
      <p class="text-xl text-gray-600">
        Got a question, tip, or just want to talk golf? We'd love to hear from you.
      </p>
    </div>
    
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
      <div class="space-y-6">
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">📧 Email</h2>
          <p class="text-gray-600">
            <a href="mailto:hello@birdiereport.com" class="text-green-700 hover:text-green-800 underline">hello@birdiereport.com</a>
          </p>
        </div>
        
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">💼 Business Inquiries</h2>
          <p class="text-gray-600">
            For partnerships, sponsorships, or advertising inquiries, email us at 
            <a href="mailto:hello@birdiereport.com" class="text-green-700 hover:text-green-800 underline">hello@birdiereport.com</a>.
          </p>
        </div>
        
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">📝 Product Reviews</h2>
          <p class="text-gray-600">
            Want us to review your product? Send us an email with details. We only review products we can genuinely test and evaluate — no pay-for-play reviews.
          </p>
        </div>
        
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">🐛 Found a Bug?</h2>
          <p class="text-gray-600">
            Broken link? Typo? Something not working right? Let us know and we'll fix it.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
