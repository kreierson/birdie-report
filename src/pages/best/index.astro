---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog').catch(() => []);
const bestPosts = allPosts
  .filter(post => post.data.category === 'best')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categories = [
  { 
    name: 'Drivers', 
    slug: 'drivers', 
    description: 'Best drivers for distance, forgiveness, and every budget',
    icon: '🏌️‍♂️',
    color: 'bg-blue-100 text-blue-800'
  },
  { 
    name: 'Irons', 
    slug: 'irons', 
    description: 'Game improvement and player irons that actually work',
    icon: '🏌️',
    color: 'bg-green-100 text-green-800'
  },
  { 
    name: 'Putters', 
    slug: 'putters', 
    description: 'Blade, mallet, and specialty putters for every stroke type',
    icon: '⛳',
    color: 'bg-purple-100 text-purple-800'
  },
  { 
    name: 'Golf Balls', 
    slug: 'golf-balls', 
    description: 'Performance and value picks for every handicap',
    icon: '⚪',
    color: 'bg-orange-100 text-orange-800'
  },
  { 
    name: 'Wedges', 
    slug: 'wedges', 
    description: 'Scoring clubs for every lie and short game situation',
    icon: '⛳',
    color: 'bg-red-100 text-red-800'
  },
  { 
    name: 'Rangefinders', 
    slug: 'rangefinders', 
    description: 'Laser and GPS devices that won\'t break the bank',
    icon: '🎯',
    color: 'bg-indigo-100 text-indigo-800'
  },
  { 
    name: 'Golf Bags', 
    slug: 'bags', 
    description: 'Stand, cart, and carry bags for every golfer',
    icon: '🎒',
    color: 'bg-yellow-100 text-yellow-800'
  },
  { 
    name: 'Golf Shoes', 
    slug: 'shoes', 
    description: 'Comfort, style, and performance from tee to green',
    icon: '👟',
    color: 'bg-gray-100 text-gray-800'
  },
  { 
    name: 'Training Aids', 
    slug: 'training-aids', 
    description: 'Practice tools that actually improve your game',
    icon: '📚',
    color: 'bg-teal-100 text-teal-800'
  },
  { 
    name: 'Golf Accessories', 
    slug: 'accessories', 
    description: 'Gloves, tees, divot tools, and essential gear',
    icon: '🧤',
    color: 'bg-pink-100 text-pink-800'
  }
];

const featuredGuides = [
  {
    title: "Best Drivers 2026: Every Budget",
    description: "Tested 15+ drivers to find the longest, most forgiving options at every price point.",
    image: "/images/best/drivers-2026.jpg",
    slug: "best-drivers-2026"
  },
  {
    title: "Best Golf Balls for High Handicappers",
    description: "Stop losing $5 balls in the woods. These perform just as well for way less money.",
    image: "/images/best/golf-balls-high-handicap.jpg", 
    slug: "best-golf-balls-high-handicappers"
  },
  {
    title: "Best Putters Under $200",
    description: "Premium feel without premium pricing. Tested over 20 putters to find the gems.",
    image: "/images/best/putters-under-200.jpg",
    slug: "best-putters-under-200"
  }
];
---

<BaseLayout 
  title="Best Golf Equipment 2026 - Buyer's Guides & Reviews | The Birdie Report"
  description="Find the best golf equipment for your game and budget. Comprehensive buyer's guides tested by real golfers, not sponsored content."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        Best Golf Equipment 2026
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Comprehensive buyer's guides for every piece of golf equipment. 
        We test everything with our own money and tell you what actually works.
      </p>
    </div>

    <!-- Featured Guides -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">🔥 Featured Buyer's Guides</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {featuredGuides.map(guide => (
          <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow border-2 border-green-200">
            <div class="aspect-video w-full relative overflow-hidden">
              <div class="absolute top-4 left-4 z-10">
                <span class="bg-green-600 text-white text-sm font-bold px-3 py-1 rounded-full">
                  UPDATED 2026
                </span>
              </div>
              <img 
                src={guide.image} 
                alt={guide.title}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              />
            </div>
            
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-3 line-clamp-2">
                <a href={`/blog/${guide.slug}/`} class="hover:text-green-700 transition-colors">
                  {guide.title}
                </a>
              </h3>
              
              <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                {guide.description}
              </p>
              
              <a 
                href={`/blog/${guide.slug}/`}
                class="inline-flex items-center text-green-700 font-semibold hover:text-green-800 transition-colors"
              >
                Read Guide
                <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Equipment Categories -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Shop by Equipment Category</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map(category => (
          <a 
            href={`/best/${category.slug}/`}
            class="group bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-all hover:border-green-300"
          >
            <div class="flex items-start mb-4">
              <div class="text-3xl mr-4">{category.icon}</div>
              <div class="flex-1">
                <div class="flex items-center justify-between mb-2">
                  <h3 class="text-lg font-semibold text-gray-900 group-hover:text-green-700">
                    {category.name}
                  </h3>
                  <span class={`px-2 py-1 text-xs font-medium rounded ${category.color}`}>
                    BEST OF
                  </span>
                </div>
                <p class="text-gray-600 text-sm mb-4">{category.description}</p>
              </div>
            </div>
            
            <div class="flex items-center text-green-700 text-sm font-medium">
              View Best {category.name}
              <svg class="ml-1 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Latest Best Of Articles -->
    {bestPosts.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Latest Buyer's Guides</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {bestPosts.map(post => (
            <article class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
              <a href={`/blog/${post.slug}/`}>
                <img 
                  src={post.data.featured_image} 
                  alt={post.data.title}
                  class="w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
                />
              </a>
              
              <div class="p-6">
                <div class="flex items-center space-x-2 text-sm text-gray-500 mb-2">
                  <span class="px-2 py-1 bg-green-100 text-green-700 rounded text-xs font-medium">
                    BEST OF
                  </span>
                  <time>{new Date(post.data.date).toLocaleDateString()}</time>
                </div>
                
                <h3 class="text-xl font-semibold text-gray-900 mb-3 line-clamp-2">
                  <a href={`/blog/${post.slug}/`} class="hover:text-green-700 transition-colors">
                    {post.data.title}
                  </a>
                </h3>
                
                <p class="text-gray-600 text-sm line-clamp-3 mb-4">
                  {post.data.description}
                </p>
                
                <a 
                  href={`/blog/${post.slug}/`}
                  class="inline-flex items-center text-green-700 font-medium hover:text-green-800 transition-colors"
                >
                  Read Guide
                  <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Testing Philosophy -->
    <section class="bg-green-50 rounded-lg p-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Testing Philosophy</h2>
        <p class="text-lg text-gray-700 mb-8">
          We don't just hit a few balls at a demo day and call it a review. 
          Every piece of equipment gets months of real-world testing.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="w-16 h-16 bg-green-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">💰</span>
            </div>
            <h3 class="font-semibold text-gray-900 text-sm mb-2">We Buy Our Own Gear</h3>
            <p class="text-gray-600 text-xs">Every club, ball, and accessory purchased with our own money</p>
          </div>
          
          <div>
            <div class="w-16 h-16 bg-green-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🏌️</span>
            </div>
            <h3 class="font-semibold text-gray-900 text-sm mb-2">Real-World Testing</h3>
            <p class="text-gray-600 text-xs">Minimum 2-3 months of actual rounds, not just range sessions</p>
          </div>
          
          <div>
            <div class="w-16 h-16 bg-green-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">📊</span>
            </div>
            <h3 class="font-semibold text-gray-900 text-sm mb-2">Data-Driven</h3>
            <p class="text-gray-600 text-xs">Shot tracking, launch monitor data, and performance metrics</p>
          </div>
          
          <div>
            <div class="w-16 h-16 bg-green-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🗣️</span>
            </div>
            <h3 class="font-semibold text-gray-900 text-sm mb-2">Honest Opinions</h3>
            <p class="text-gray-600 text-xs">If it sucks, we'll tell you. If it's great, we'll tell you that too</p>
          </div>
        </div>

        <div class="mt-8 bg-white rounded-lg p-6 border border-green-200">
          <h3 class="font-semibold text-gray-900 mb-2">Why Trust Our Reviews?</h3>
          <p class="text-gray-700 text-sm">
            We're not professional golfers, and we're not sponsored by equipment companies. 
            We're mid-handicap golfers who test gear the way you'd actually use it. 
            Our reviews are written by golfers, for golfers.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>