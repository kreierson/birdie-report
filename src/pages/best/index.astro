---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog').catch(() => []);
const bestPosts = allPosts
  .filter(post => post.data.category === 'best')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const heroPost = bestPosts[0];
const remaining = bestPosts.slice(1);

const subcategoryMap: Record<string, any> = {
  'drivers': bestPosts.find(p => p.slug.includes('driver')),
  'irons': bestPosts.find(p => p.slug.includes('iron')),
  'putters': bestPosts.find(p => p.slug.includes('putter') && !p.slug.includes('under')),
  'balls': bestPosts.find(p => p.slug.includes('golf-balls') && !p.slug.includes('high')),
  'wedges': bestPosts.find(p => p.slug.includes('wedge')),
  'rangefinders': bestPosts.find(p => p.slug.includes('rangefinder') && !p.slug.includes('under')),
  'bags': bestPosts.find(p => p.slug.includes('bag')),
  'shoes': bestPosts.find(p => p.slug.includes('shoe')),
};

const categories = [
  { name: 'Drivers', key: 'drivers', icon: '🏌️' },
  { name: 'Irons', key: 'irons', icon: '🏌️' },
  { name: 'Putters', key: 'putters', icon: '⛳' },
  { name: 'Golf Balls', key: 'balls', icon: '⚪' },
  { name: 'Wedges', key: 'wedges', icon: '🏌️' },
  { name: 'Rangefinders', key: 'rangefinders', icon: '🎯' },
  { name: 'Golf Bags', key: 'bags', icon: '🎒' },
  { name: 'Golf Shoes', key: 'shoes', icon: '👟' },
];

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout 
  title="Best Golf Equipment 2026 — Buyer's Guides | The Birdie Report"
  description="Find the best golf equipment for your game and budget. Comprehensive buyer's guides tested by real golfers."
>
  <!-- Hero -->
  {heroPost && (
    <section class="relative bg-forest-950 overflow-hidden">
      <div class="absolute inset-0">
        <img src={heroPost.data.featured_image} alt={heroPost.data.title} class="w-full h-full object-cover opacity-35" />
        <div class="absolute inset-0 bg-gradient-to-t from-forest-950 via-forest-950/60 to-forest-950/20"></div>
      </div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
        <div class="max-w-3xl">
          <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-wider rounded-sm mb-4 bg-gold-500 text-forest-900">
            Best Of 2026
          </span>
          <h1 class="text-3xl md:text-5xl font-display font-black text-white leading-tight mb-4">
            Buyer's Guides & Best Equipment
          </h1>
          <p class="text-lg text-white/70 mb-8 max-w-2xl">
            Comprehensive buyer's guides tested with our own money. We tell you what actually works.
          </p>
        </div>
      </div>
    </section>
  )}

  <!-- Quick Links Grid -->
  <section class="py-10 bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-display font-bold text-forest-900 mb-4 uppercase tracking-wide">Jump to Category</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3">
        {categories.map(cat => {
          const post = subcategoryMap[cat.key];
          return (
            <a 
              href={post ? `/blog/${post.slug}/` : '#'} 
              class={`text-center p-3 rounded-lg border transition-all hover:shadow-md ${post ? 'bg-white border-gray-200 hover:border-gold-400' : 'bg-gray-100 border-gray-200 opacity-50'}`}
            >
              <div class="text-2xl mb-1">{cat.icon}</div>
              <div class="text-xs font-bold text-gray-900">{cat.name}</div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- All Guides -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-display font-bold text-forest-900 mb-8">
        <span class="border-b-4 border-gold-500 pb-1">All Buyer's Guides</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {bestPosts.map((post, i) => (
          <article class={`group ${i === 0 ? 'md:col-span-2 lg:col-span-2' : ''}`}>
            <a href={`/blog/${post.slug}/`} class="block relative overflow-hidden rounded-lg mb-3">
              <img 
                src={post.data.featured_image} 
                alt={post.data.title}
                class={`w-full object-cover group-hover:scale-105 transition-transform duration-500 ${i === 0 ? 'h-52 md:h-80' : 'h-48'}`}
                loading="lazy"
              />
              <div class="absolute top-3 left-3">
                <span class="bg-gold-500 text-forest-900 text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-sm">Best Of 2026</span>
              </div>
            </a>
            <div>
              <h3 class={`font-semibold text-gray-900 leading-snug line-clamp-2 ${i === 0 ? 'text-xl md:text-2xl font-display' : 'text-base'}`}>
                <a href={`/blog/${post.slug}/`} class="hover:text-forest-700 transition-colors">
                  {post.data.title}
                </a>
              </h3>
              <p class="text-gray-600 text-sm mt-2 line-clamp-2">{post.data.description}</p>
              <time class="text-xs text-gray-400 mt-2 block">{formatDate(post.data.date)}</time>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
