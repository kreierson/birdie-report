---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog').catch(() => []);
const bestPosts = allPosts
  .filter(post => post.data.category === 'best')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Map subcategories to their best article
const subcategoryMap = {
  'drivers': bestPosts.find(p => p.slug.includes('driver')),
  'irons': bestPosts.find(p => p.slug.includes('iron')),
  'putters': bestPosts.find(p => p.slug.includes('putter') && !p.slug.includes('under')),
  'balls': bestPosts.find(p => p.slug.includes('golf-balls') && !p.slug.includes('high')),
  'wedges': bestPosts.find(p => p.slug.includes('wedge')),
  'rangefinders': bestPosts.find(p => p.slug.includes('rangefinder') && !p.slug.includes('under')),
  'bags': bestPosts.find(p => p.slug.includes('bag')),
  'shoes': bestPosts.find(p => p.slug.includes('shoe')),
};

const categories = [
  { name: 'Drivers', key: 'drivers', description: 'Best drivers for distance, forgiveness, and every budget', icon: '🏌️‍♂️' },
  { name: 'Irons', key: 'irons', description: 'Game improvement and player irons that actually work', icon: '🏌️' },
  { name: 'Putters', key: 'putters', description: 'Blade, mallet, and specialty putters for every stroke type', icon: '⛳' },
  { name: 'Golf Balls', key: 'balls', description: 'Performance and value picks for every handicap', icon: '⚪' },
  { name: 'Wedges', key: 'wedges', description: 'Scoring clubs for every lie and short game situation', icon: '🏌️' },
  { name: 'Rangefinders', key: 'rangefinders', description: 'Laser and GPS devices that won\'t break the bank', icon: '🎯' },
  { name: 'Golf Bags', key: 'bags', description: 'Stand, cart, and carry bags for every golfer', icon: '🎒' },
  { name: 'Golf Shoes', key: 'shoes', description: 'Comfort, style, and performance from tee to green', icon: '👟' },
];

// Featured guides — pull directly from actual posts
const featuredSlugs = ['best-drivers-2026', 'best-golf-balls-high-handicappers', 'best-putters-2026'];
const featuredGuides = featuredSlugs
  .map(slug => bestPosts.find(p => p.slug === slug))
  .filter(Boolean);
---

<BaseLayout 
  title="Best Golf Equipment 2026 - Buyer's Guides & Reviews | The Birdie Report"
  description="Find the best golf equipment for your game and budget. Comprehensive buyer's guides tested by real golfers."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Best Golf Equipment 2026</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Comprehensive buyer's guides for every piece of golf equipment. 
        We test everything with our own money and tell you what actually works.
      </p>
    </div>

    <!-- Featured Guides -->
    {featuredGuides.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">🔥 Featured Buyer's Guides</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {featuredGuides.map(guide => (
            <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow border-2 border-green-200">
              <div class="aspect-video w-full relative overflow-hidden">
                <div class="absolute top-4 left-4 z-10">
                  <span class="bg-green-600 text-white text-sm font-bold px-3 py-1 rounded-full">UPDATED 2026</span>
                </div>
                <img 
                  src={guide.data.featured_image} 
                  alt={guide.data.title}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-gray-900 mb-3 line-clamp-2">
                  <a href={`/blog/${guide.slug}/`} class="hover:text-green-700 transition-colors">{guide.data.title}</a>
                </h3>
                <p class="text-gray-600 text-sm mb-4 line-clamp-3">{guide.data.description}</p>
                <a href={`/blog/${guide.slug}/`} class="inline-flex items-center text-green-700 font-semibold hover:text-green-800 transition-colors">
                  Read Guide
                  <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Equipment Categories — link to actual articles -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Buyer's Guides by Category</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map(category => {
          const post = subcategoryMap[category.key];
          const href = post ? `/blog/${post.slug}/` : '#';
          return (
            <a 
              href={href}
              class={`group bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-all hover:border-green-300 ${!post ? 'opacity-50' : ''}`}
            >
              <div class="flex items-start mb-4">
                <div class="text-3xl mr-4">{category.icon}</div>
                <div class="flex-1">
                  <div class="flex items-center justify-between mb-2">
                    <h3 class="text-lg font-semibold text-gray-900 group-hover:text-green-700">{category.name}</h3>
                    <span class="px-2 py-1 text-xs font-medium rounded bg-green-100 text-green-800">
                      {post ? 'BEST OF' : 'COMING SOON'}
                    </span>
                  </div>
                  <p class="text-gray-600 text-sm">{category.description}</p>
                </div>
              </div>
              <div class="flex items-center text-green-700 text-sm font-medium">
                {post ? `View Best ${category.name}` : 'Coming Soon'}
                <svg class="ml-1 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- All Best Of Articles -->
    {bestPosts.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">All Buyer's Guides</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {bestPosts.map(post => (
            <article class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
              <a href={`/blog/${post.slug}/`}>
                <img 
                  src={post.data.featured_image} 
                  alt={post.data.title}
                  class="w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </a>
              <div class="p-6">
                <div class="flex items-center space-x-2 text-sm text-gray-500 mb-2">
                  <span class="px-2 py-1 bg-green-100 text-green-700 rounded text-xs font-medium">BEST OF</span>
                  <time>{new Date(post.data.date).toLocaleDateString()}</time>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-3 line-clamp-2">
                  <a href={`/blog/${post.slug}/`} class="hover:text-green-700 transition-colors">{post.data.title}</a>
                </h3>
                <p class="text-gray-600 text-sm line-clamp-3">{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
