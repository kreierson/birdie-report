---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryPage from '../../components/CategoryPage.astro';

const priorityComparisons = [
  {
    href: '/blog/titleist-gt2-vs-ping-g440-driver/',
    title: 'Titleist GT2 vs Ping G440 Max Driver',
    note: 'Two elite drivers with very different strengths: Titleist speed and Ping forgiveness.'
  },
  {
    href: '/blog/callaway-elyte-vs-titleist-gt2-driver/',
    title: 'Callaway Elyte vs Titleist GT2 Driver',
    note: 'A value-focused driver decision built around new-model tech versus clearance pricing.'
  },
  {
    href: '/blog/ping-hoofer-lite-vs-titleist-players-s4-stadry/',
    title: 'Ping Hoofer Lite vs Titleist Players S4 StaDry',
    note: 'The walking-bag question: lighter carry comfort or better wet-weather protection.'
  },
  {
    href: '/blog/cleveland-cbx4-vs-callaway-jaws-raw-wedges/',
    title: 'Cleveland CBX4 vs Callaway Jaws Raw Wedges',
    note: 'A practical wedge choice between forgiveness-first scoring and more creative shotmaking.'
  },
];
---

<BaseLayout 
  title="Golf Equipment Comparisons | The Birdie Report"
  description="Head-to-head product comparisons to help you decide what's right for your game."
>
  <CategoryPage
    category="versus"
    title="Head-to-Head Comparisons"
    description="Head-to-head product comparisons to help you decide what's right for your game."
    accentColor="purple"
    badgeLabel="Versus"
    badgeClass="bg-purple-600 text-white"
  >
    <section class="mt-16 border-t border-gray-200 pt-10">
      <div class="max-w-4xl">
        <p class="text-xs font-bold uppercase tracking-wide text-purple-700 mb-2">Popular Buyer Matchups</p>
        <h2 class="text-2xl font-display font-bold text-forest-900 mb-3">Start With the Decisions Golfers Actually Debate</h2>
        <p class="text-gray-600 mb-6">
          These head-to-head guides cover the gear choices where the right answer depends on your swing, budget, and how you actually play.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {priorityComparisons.map(item => (
          <a href={item.href} class="block rounded-lg border border-gray-200 bg-white p-5 hover:border-purple-300 hover:shadow-md transition-all">
            <h3 class="font-display font-bold text-lg text-forest-900 mb-2">{item.title}</h3>
            <p class="text-sm text-gray-600">{item.note}</p>
          </a>
        ))}
      </div>
    </section>
  </CategoryPage>
</BaseLayout>
