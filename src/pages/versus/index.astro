---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog').catch(() => []);
const versusPosts = allPosts
  .filter(post => post.data.category === 'versus')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Featured comparisons (would be dynamic in real implementation)
const featuredComparisons = [
  {
    title: "TaylorMade Qi35 vs Callaway Elyte Driver",
    subtitle: "2026's Hottest Driver Battle", 
    description: "Both drivers promise huge distance gains. We tested them head-to-head for 3 months to find the winner.",
    image: "/images/versus/taylormade-vs-callaway-driver.jpg",
    slug: "taylormade-qi35-vs-callaway-elyte-driver",
    winner: "TaylorMade Qi35",
    categories: ["Distance", "Forgiveness", "Sound/Feel", "Value"]
  },
  {
    title: "Titleist Pro V1 vs Pro V1x 2026",
    subtitle: "Which Premium Ball is Right for You?",
    description: "Same company, similar price, totally different performance. Here's how to choose.",
    image: "/images/versus/prov1-vs-prov1x.jpg", 
    slug: "titleist-prov1-vs-prov1x-2026",
    winner: "Pro V1x",
    categories: ["Distance", "Spin", "Feel", "Durability"]
  },
  {
    title: "Scotty Cameron vs Odyssey Putters",
    subtitle: "$500 vs $200 Putting Performance",
    description: "Is the premium price worth it? We tested 12 putters to find out.",
    image: "/images/versus/scotty-vs-odyssey.jpg",
    slug: "scotty-cameron-vs-odyssey-putters",
    winner: "Odyssey",
    categories: ["Performance", "Feel", "Value", "Durability"]
  }
];

const comparisonCategories = [
  {
    name: "Driver Battles",
    icon: "🏌️‍♂️",
    description: "Head-to-head driver testing across all price points",
    count: 8
  },
  {
    name: "Iron Comparisons", 
    icon: "🏌️",
    description: "Game improvement vs player irons, brand battles",
    count: 12
  },
  {
    name: "Putter Showdowns",
    icon: "⛳",
    description: "Blade vs mallet, premium vs value putting tests",
    count: 6
  },
  {
    name: "Ball Tests",
    icon: "⚪",
    description: "Performance ball comparisons and value alternatives",
    count: 15
  },
  {
    name: "Rangefinder Face-offs",
    icon: "🎯", 
    description: "Laser vs GPS, budget vs premium distance measuring",
    count: 4
  },
  {
    name: "Shoe Shootouts",
    icon: "👟",
    description: "Comfort, style, and performance across golf footwear",
    count: 7
  }
];
---

<BaseLayout 
  title="Golf Equipment Comparisons - Head-to-Head Tests | The Birdie Report"
  description="Comprehensive head-to-head golf equipment comparisons. We test competing products side-by-side so you know which one actually performs better."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        Equipment Battles
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Head-to-head equipment testing to settle the debates. We test competing products 
        side-by-side so you know which one actually performs better for real golfers.
      </p>
    </div>

    <!-- Featured Comparisons -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">🔥 Latest Battle Tests</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-8">
        {featuredComparisons.map(comparison => (
          <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow border-2 border-red-200">
            <!-- Winner Badge -->
            <div class="absolute z-10 top-4 right-4">
              <span class="bg-green-600 text-white text-xs font-bold px-2 py-1 rounded">
                WINNER: {comparison.winner}
              </span>
            </div>
            
            <div class="aspect-video w-full relative overflow-hidden">
              <img 
                src={comparison.image} 
                alt={comparison.title}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              />
            </div>
            
            <div class="p-6">
              <div class="mb-3">
                <span class="text-sm font-medium text-red-600 uppercase tracking-wide">
                  {comparison.subtitle}
                </span>
              </div>
              
              <h3 class="text-xl font-bold text-gray-900 mb-3 line-clamp-2">
                <a href={`/blog/${comparison.slug}/`} class="hover:text-green-700 transition-colors">
                  {comparison.title}
                </a>
              </h3>
              
              <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                {comparison.description}
              </p>
              
              <!-- Categories tested -->
              <div class="mb-4">
                <p class="text-xs text-gray-500 mb-2">Categories Tested:</p>
                <div class="flex flex-wrap gap-1">
                  {comparison.categories.map(category => (
                    <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded">
                      {category}
                    </span>
                  ))}
                </div>
              </div>
              
              <a 
                href={`/blog/${comparison.slug}/`}
                class="inline-flex items-center text-red-700 font-semibold hover:text-red-800 transition-colors"
              >
                See Battle Results
                <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Comparison Categories -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Browse Battle Categories</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {comparisonCategories.map(category => (
          <a 
            href={`/versus/${category.name.toLowerCase().replace(/\s+/g, '-')}/`}
            class="group bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-all hover:border-red-300"
          >
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-start">
                <div class="text-3xl mr-4">{category.icon}</div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 group-hover:text-red-700 mb-2">
                    {category.name}
                  </h3>
                  <p class="text-gray-600 text-sm">{category.description}</p>
                </div>
              </div>
              <span class="bg-red-100 text-red-700 text-xs font-bold px-2 py-1 rounded">
                {category.count} BATTLES
              </span>
            </div>
            
            <div class="flex items-center text-red-700 text-sm font-medium">
              View {category.name}
              <svg class="ml-1 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Latest Versus Articles -->
    {versusPosts.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">All Battle Tests</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {versusPosts.map(post => (
            <article class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
              <a href={`/blog/${post.slug}/`}>
                <img 
                  src={post.data.featured_image} 
                  alt={post.data.title}
                  class="w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
                />
              </a>
              
              <div class="p-6">
                <div class="flex items-center space-x-2 text-sm text-gray-500 mb-2">
                  <span class="px-2 py-1 bg-red-100 text-red-700 rounded text-xs font-medium">
                    VERSUS
                  </span>
                  <time>{new Date(post.data.date).toLocaleDateString()}</time>
                </div>
                
                <h3 class="text-xl font-semibold text-gray-900 mb-3 line-clamp-2">
                  <a href={`/blog/${post.slug}/`} class="hover:text-green-700 transition-colors">
                    {post.data.title}
                  </a>
                </h3>
                
                <p class="text-gray-600 text-sm line-clamp-3 mb-4">
                  {post.data.description}
                </p>
                
                <a 
                  href={`/blog/${post.slug}/`}
                  class="inline-flex items-center text-red-700 font-medium hover:text-red-800 transition-colors"
                >
                  See Results
                  <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Battle Testing Philosophy -->
    <section class="bg-red-50 rounded-lg p-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">⚔️ How We Battle Test</h2>
        <p class="text-lg text-gray-700 mb-8">
          Our versus tests aren't based on specs or marketing claims. We test competing products 
          side-by-side in real conditions to determine actual winners and losers.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="w-16 h-16 bg-red-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🥊</span>
            </div>
            <h3 class="font-semibold text-gray-900 text-sm mb-2">Head-to-Head Testing</h3>
            <p class="text-gray-600 text-xs">Same golfer, same day, same conditions for fair comparison</p>
          </div>
          
          <div>
            <div class="w-16 h-16 bg-red-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">📊</span>
            </div>
            <h3 class="font-semibold text-gray-900 text-sm mb-2">Multiple Categories</h3>
            <p class="text-gray-600 text-xs">Distance, accuracy, feel, value, and real-world performance</p>
          </div>
          
          <div>
            <div class="w-16 h-16 bg-red-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🏆</span>
            </div>
            <h3 class="font-semibold text-gray-900 text-sm mb-2">Clear Winners</h3>
            <p class="text-gray-600 text-xs">No ties, no "it depends" - we pick an overall winner</p>
          </div>
          
          <div>
            <div class="w-16 h-16 bg-red-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">💰</span>
            </div>
            <h3 class="font-semibold text-gray-900 text-sm mb-2">Value Matters</h3>
            <p class="text-gray-600 text-xs">Price is always factored into our final recommendations</p>
          </div>
        </div>

        <div class="mt-8 bg-white rounded-lg p-6 border border-red-200">
          <h3 class="font-semibold text-gray-900 mb-2">No Sponsored Content</h3>
          <p class="text-gray-700 text-sm">
            We buy all equipment with our own money and have no relationships with manufacturers. 
            Our winners are based purely on performance, not who pays us.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>