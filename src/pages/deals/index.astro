---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryPage from '../../components/CategoryPage.astro';
import CommercialOpportunityPanel from '../../components/CommercialOpportunityPanel.astro';
---

<BaseLayout 
  title="Golf Deals & Savings | The Birdie Report"
  description="The best golf deals we've found this week. Real prices, real savings."
>
  <CategoryPage
    category="deals"
    title="Deals & Savings"
    description="The best golf deals we've found this week. Real prices, real savings, real affiliate links."
    accentColor="orange"
    badgeLabel="Deals"
    badgeClass="bg-orange-500 text-white"
  >
    <CommercialOpportunityPanel
      title="Deal Readers Usually Need A Buying Fork Next"
      description="After a reader checks a sale price, the next click should help them decide whether the discounted product is actually the right category, tier, or upgrade."
    />
  </CategoryPage>
</BaseLayout>
